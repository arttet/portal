{
  "name": "portal",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:svelte": "eslint .",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.svelte-kit\" \"#coverage\"",
    "test": "bun run test:unit:coverage && bun run test:playwright",
    "test:unit": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:playwright": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "cspell": "10.0.1",
    "dprint": "0.54.0",
    "eslint": "^10.5.0",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.7.0",
    "knip": "6.20.0",
    "markdownlint-cli2": "^0.22.1",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "playwright": "^1.61.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "svelte-eslint-parser": "^1.8.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vitest-browser-svelte": "^2.1.1"
  },
  "overrides": {
    "cookie": "0.7.2",
    "js-yaml": "4.2.0",
    "markdown-it": "14.2.0"
  },
  "patchedDependencies": {
    "markdownlint-cli2@0.22.1": "patches/markdownlint-cli2@0.22.1.patch"
  }
}
