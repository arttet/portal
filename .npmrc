# Runtime strictness
engine-strict=true
strict-peer-deps=true

# Reproducible dependency changes
package-lock=true
save-exact=true

# Security / audit behavior
audit=true
audit-level=high

# Less noise
fund=false

# Cache behavior
prefer-offline=true
fetch-retries=3
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000
fetch-timeout=300000
